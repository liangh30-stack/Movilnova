# Gemini API Key (required for AI features)
GEMINI_API_KEY=

# Employee PINs (optional - defaults provided for demo)
PIN_ADMIN=0000
PIN_MANAGER=1234
PIN_WORKER=8888

# Google Analytics 4 (optional)
# Create a GA4 property at https://analytics.google.com → Admin → Create Property
# Then get the Measurement ID from Admin → Data Streams → Web → Measurement ID
VITE_GA_MEASUREMENT_ID=

# Sentry Configuration (optional)
# Get your DSN from Sentry: Project Settings > Client Keys (DSN)
VITE_SENTRY_DSN=
# Set to 'true' to enable Sentry in development
VITE_SENTRY_ENABLED=false

# Firebase Configuration
# Get these values from Firebase Console: Project Settings > General > Your apps > Web app
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Email (Resend) — API key stored server-side in functions/.env, NOT here.
# Set RESEND_API_KEY and RESEND_FROM_EMAIL in functions/.env
# Get API key from: https://resend.com/api-keys

# Company Information (for legal pages - defaults provided)
VITE_COMPANY_NAME=MovilNova S.L.
VITE_COMPANY_NIF=B-12345678
VITE_COMPANY_ADDRESS=C/ Principal 123, 36400 Porriño, Pontevedra
VITE_COMPANY_EMAIL=info@movilnova.es
VITE_COMPANY_PHONE=+34 986 123 456
VITE_COMPANY_DPO_EMAIL=dpo@movilnova.es
VITE_COMPANY_REGISTRY=Registro Mercantil de Pontevedra, Tomo XXX, Folio XXX
VITE_COMPANY_CITY=Pontevedra

# Stripe Configuration
# Get keys from: https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=

# Firebase Cloud Messaging (FCM) — for push notifications
# Generate in Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
VITE_FIREBASE_VAPID_KEY=

# MCP Server Configuration (optional - for Claude Code Agents)
# Get Brave API key from: https://brave.com/search/api/
BRAVE_API_KEY=
# Get GitHub token from: https://github.com/settings/tokens
GITHUB_TOKEN=
